<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<!--
  H1 卡段② BE 波 2c — V-4 写：image_asset 行（admin 直传 OSS 场景）。
  namespace 独立 (org.dromara.bookadmin.mapper.AdminImageAssetWriteMapper)，
  不动 ruoyi-book/ 模块。

  字段策略详见 AdminImageAssetWriteMapper.java javadoc。
-->
<mapper namespace="org.dromara.bookadmin.mapper.AdminImageAssetWriteMapper">

    <!--
      useGeneratedKeys + keyProperty 回填自增 id 到 idHolder map 的 "id" key。
      MyBatis 对 @Param("idHolder") 的 map 用 keyProperty="idHolder.id" 即可
      把生成的主键写回 map。Service 层 new HashMap 传进来，调用后 get("id")。
    -->
    <insert id="insertAdminUpload"
            useGeneratedKeys="true"
            keyProperty="idHolder.id">
        INSERT INTO image_asset (
            src_url,
            url_hash,
            host,
            asset_kind,
            ext,
            rel_path,
            local_path,
            entity_type,
            entity_ref,
            status,
            file_size,
            content_type,
            oss_url,
            oss_uploaded_ts,
            created_at
        ) VALUES (
            #{srcUrl},
            #{urlHash},
            #{host},
            #{assetKind},
            #{ext},
            #{relPath},
            #{localPath},
            'question',
            #{entityRef},
            'ok',
            #{fileSize},
            #{contentType},
            #{ossUrl},
            NOW(),
            NOW()
        )
    </insert>

</mapper>
